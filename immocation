    <div class="card">
      <h4>🏦 Vermögens- &amp; Restschuldentwicklung</h4>
      <p style="font-size:11px;color:#5a6e82;margin-bottom:14px">Nettovermögen = Immobilienwert (bei ${fmtPct(S.wertsteigerung)} p.a.) minus Restschuld</p>
      ${lineChart([{label:'Nettovermögen (EK-Anteil)',data:C.vermoegenArr,color:'#4ade80'},{label:'Restschuld',data:C.restschuldArr,color:'#f87171'}],yrLabels,210,0)}
    </div>
    <div class="card">
      <h4>⚖️ Zinsen vs. Tilgung über die Zeit</h4>
      <p style="font-size:11px;color:#5a6e82;margin-bottom:14px">Mit sinkender Restschuld verringert sich der Zinsanteil — Tilgungsanteil bleibt konstant</p>
      <div style="display:flex;gap:2px;align-items:flex-end;height:150px;padding:0 4px">`;
  C.years.forEach((_, i)=>{
    const z=C.zinsenArr[i],t=C.tilgungArr[i];
    const maxTot=C.zinsenArr[0]+C.tilgungArr[0];
    const zH=(z/maxTot)*110,tH=(t/maxTot)*110;
    if(C.years.length>20&&i%2!==0&&i!==C.years.length-1)return;
    if(C.years.length>30&&i%3!==0&&i!==C.years.length-1)return;
    kostenHTML+=`<div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end">
      <div style="width:100%">
        <div style="width:100%;height:${zH}px;background:#f87171;border-radius:2px 2px 0 0;min-height:${z>0?'1px':'0'}"></div>
        <div style="width:100%;height:${tH}px;background:#4fc3f7"></div>
      </div>
      <div style="font-size:8px;color:#4a5f73;margin-top:3px">J${i+1}</div>
    </div>`;
  });
  kostenHTML+=`</div>
      <div class="legend">
        <div class="legend-item"><div class="legend-dot" style="background:#f87171"></div>Zinsanteil (sinkend)</div>
        <div class="legend-item"><div class="legend-dot" style="background:#4fc3f7"></div>Tilgungsanteil (konstant)</div>
      </div>
    </div>
    <div class="card">
      <h4>📊 Jährliche Kostenstruktur (Jahr 1)</h4>
      <div class="cost-items">`;
  const costItems=[
    {label:'Zinsen',val:C.jahreszins,color:'#f87171'},
    {label:'Tilgung',val:C.jahrestilgung,color:'#4fc3f7'},
    {label:'Verwaltung',val:C.jVerwaltung,color:'#a78bfa'},
    {label:'Instandhaltung',val:C.jInstand,color:'#fb923c'},
    {label:'Nicht umlegb. NK',val:C.jNichtUmlegbar,color:'#facc15'},
    {label:'Mietausfall',val:C.mietausfall,color:'#f472b6'},
  ];
  const costTotal=costItems.reduce((s,i)=>s+i.val,0);
  costItems.forEach(item=>{
    const pct=costTotal>0?item.val/costTotal*100:0;
    kostenHTML+=`<div class="cost-item">
      <div class="cost-item-top">
        <span style="font-size:11px;color:${item.color};font-weight:600">${item.label}</span>
        <span style="font-size:10px;color:#5a6e82">${fmtDE(pct,1)}%</span>
      </div>
      <div class="cost-item-val">${fmtEur(item.val)}</div>
      <div class="bar-bg"><div class="bar-fill" style="width:${pct}%;background:${item.color}"></div></div>
    </div>`;
  });
  kostenHTML+=`</div>
      <p class="disclaimer">⚠️ Vereinfachte Modellrechnung. Zinsanteil sinkt mit der Restschuld (lineare Tilgung). Bei echten Annuitätendarlehen bleibt die Rate konstant. Für verbindliche Berechnungen Steuerberater/Finanzberater hinzuziehen.</p>
    </div>`;
  document.getElementById('tab-kosten').innerHTML=kostenHTML;
}

// ─── HILFSFUNKTIONEN ─────────────────────────────────────────────────
function kpiCard(label,value,sub,highlight,positive,negative){
  const bg=highlight?'linear-gradient(135deg,#1a3a5c 0%,#0d2137 100%)':'rgba(255,255,255,0.03)';
  const border=highlight?'#4fc3f7':'rgba(255,255,255,0.07)';
  const col=positive?'#4ade80':negative?'#f87171':highlight?'#4fc3f7':'#e8f4fd';
  const fs=highlight?'26px':'22px';
  return `<div class="kpi-card" style="background:${bg};border:1px solid ${border};box-shadow:${highlight?'0 0 24px rgba(79,195,247,0.15)':'none'}">
    <div class="kpi-label">${label}</div>
    <div class="kpi-val" style="font-size:${fs};color:${col}">${value}</div>
    ${sub?`<div class="kpi-sub">${sub}</div>`:''}
  </div>`;
}
function row(label,value,sub='',bold=false,accent=''){
  const col=accent||(bold?'#e8f4fd':'#9ab0c4');
  return `<div class="row">
    <span class="row-label${bold?' bold':''}">${label}</span>
    <div>
      <div class="row-val${bold?' bold':''}" style="${accent?`color:${accent}`:''}"> ${value}</div>
      ${sub?`<div class="row-sub">${sub}</div>`:''}
    </div>
  </div>`;
}

// ─── TAB SWITCHING ───────────────────────────────────────────────────
function switchTab(id,btn){
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  ['uebersicht','lage','abschreibung','kosten'].forEach(t=>{
    document.getElementById(`tab-${t}`).style.display=t===id?'block':'none';
  });
}

// ─── SECTION COLLAPSE ────────────────────────────────────────────────
function toggleSection(header){
  const body=header.nextElementSibling;
  const arrow=header.querySelector('.arrow');
  const collapsed=body.style.display==='none';
  body.style.display=collapsed?'block':'none';
  arrow.textContent=collapsed?'▼':'▶';
}

