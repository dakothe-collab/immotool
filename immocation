    t.classList.toggle('on',S[key]);
    if(callback)callback();
    render();
  });
}

// ─── SVG LINE CHART ───────────────────────────────────────────────────
function lineChart(series,years,height=200,yMinOverride,yMaxOverride){
  const w=560,h=height,pad={top:20,right:16,bottom:28,left:68};
  const innerW=w-pad.left-pad.right,innerH=h-pad.top-pad.bottom;
  const allVals=series.flatMap(s=>s.data);
  const minV=yMinOverride!==undefined?yMinOverride:Math.min(0,...allVals)*1.15;
  const maxV=yMaxOverride!==undefined?yMaxOverride:Math.max(...allVals)*1.1;
  const range=maxV-minV||1;
  const x=i=>pad.left+(i/Math.max(years.length-1,1))*innerW;
  const y=v=>pad.top+innerH-((v-minV)/range)*innerH;
  const yTicks=5;
  let svg=`<svg viewBox="0 0 ${w} ${h}" style="width:100%;height:${height}px">`;
  for(let i=0;i<=yTicks;i++){
    const v=minV+(range/yTicks)*i;const yy=y(v);
    svg+=`<line x1="${pad.left}" y1="${yy}" x2="${w-pad.right}" y2="${yy}" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>`;
    svg+=`<text x="${pad.left-6}" y="${yy+4}" text-anchor="end" font-size="9" fill="#4a5f73">${fmtEur(v,0).replace(/\s?€/,'')}</text>`;
  }
  if(minV<0&&maxV>0){
    const z=y(0);svg+=`<line x1="${pad.left}" y1="${z}" x2="${w-pad.right}" y2="${z}" stroke="rgba(255,255,255,0.18)" stroke-width="1" stroke-dasharray="4,3"/>`;
  }
  years.forEach((yr,i)=>{
    if(i%Math.ceil(years.length/10)!==0&&i!==years.length-1)return;
    svg+=`<text x="${x(i)}" y="${h-4}" text-anchor="middle" font-size="9" fill="#4a5f73">${yr}</text>`;
  });
  series.forEach((s,si)=>{
    const pts=s.data.map((v,i)=>`${x(i)},${y(v)}`).join(' ');
    svg+=`<polyline points="${pts}" fill="none" stroke="${s.color}" stroke-width="2" stroke-linejoin="round" stroke-opacity="0.9"/>`;
    s.data.forEach((v,i)=>{
      if(i%Math.ceil(years.length/7)!==0&&i!==s.data.length-1)return;
      svg+=`<circle cx="${x(i)}" cy="${y(v)}" r="3" fill="${s.color}"/>`;
    });
    svg+=`<g transform="translate(${pad.left+si*150},${pad.top-4})"><line x1="0" y1="6" x2="14" y2="6" stroke="${s.color}" stroke-width="2"/><text x="18" y="10" font-size="9" fill="${s.color}">${s.label}</text></g>`;
  });
  return svg+'</svg>';
}

