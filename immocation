function getRegion(plz){
  if(!plz||plz.length<2)return null;
  const p2=plz.substring(0,2);
  if(PLZ_DATA[p2])return PLZ_DATA[p2];
  const p1=plz.substring(0,1);
  for(const k of Object.keys(PLZ_DATA)){if(k.startsWith(p1))return null;}
  return null;
}

// ─── BERECHNUNGEN ─────────────────────────────────────────────────────
function calc(){
  const {kaufpreis,grunderwerbsteuer,notarkosten,maklercourtage,wohnflaeche,
    eigenkapital,zinssatz,tilgung,kaltmiete,mietausfallWagnis,mietsteigerung,
    verwaltungskosten,instandhaltung,nichtUmlegbar,isNeubau,isQNG,
    gebaeudewertAnteil,steuersatz,wertsteigerung,haltedauer} = S;

  const nk_gew=kaufpreis*grunderwerbsteuer/100;
  const nk_notar=kaufpreis*notarkosten/100;
  const nk_makler=kaufpreis*maklercourtage/100;
  const gesamtNK=nk_gew+nk_notar+nk_makler;
  const gesamtInv=kaufpreis+gesamtNK;
  const nkPct=gesamtNK/kaufpreis*100;
  const darlehen=gesamtInv-eigenkapital;
  const jahreszins=darlehen*zinssatz/100;
  const jahrestilgung=darlehen*tilgung/100;
  const jahresrate=jahreszins+jahrestilgung;
  const monatsrate=jahresrate/12;
  const jKaltmiete=kaltmiete*12;
  const mietausfall=jKaltmiete*mietausfallWagnis/100;
  const effMiete=jKaltmiete-mietausfall;
  const jVerwaltung=verwaltungskosten*12;
  const jInstand=instandhaltung*wohnflaeche;
  const jNichtUmlegbar=nichtUmlegbar*12;
  const gesamtKosten=jVerwaltung+jInstand+jNichtUmlegbar;
  const noi=effMiete-gesamtKosten;
  const cfVorSteuer=noi-jahresrate;
  const bruttoRendite=jKaltmiete/kaufpreis*100;
  const nettoRendite=noi/gesamtInv*100;
  const kpFaktor=kaufpreis/jKaltmiete;
  const gebWert=kaufpreis*gebaeudewertAnteil/100;
  let afaSatz=2;if(isNeubau)afaSatz=isQNG?5:3;
  const jAfA=gebWert*afaSatz/100;
  const steuerErspar=jAfA*steuersatz/100;
  const zvE=noi-jahreszins-jAfA;
  const stLast=zvE>0?zvE*steuersatz/100:0;
  const cfNachSteuer=cfVorSteuer-stLast+(zvE<0?Math.abs(zvE)*steuersatz/100:0);
  const ekRendite=(cfNachSteuer+jahrestilgung)/Math.max(eigenkapital,1)*100;
  const endwert=kaufpreis*Math.pow(1+wertsteigerung/100,haltedauer);
  const restschuld=Math.max(0,darlehen-jahrestilgung*haltedauer);
  const ekEndwert=endwert-restschuld;
  const gesamtMiete=mietsteigerung>0?jKaltmiete*((Math.pow(1+mietsteigerung/100,haltedauer)-1)/(mietsteigerung/100)):jKaltmiete*haltedauer;

  const restschuldArr=[],zinsenArr=[],tilgungArr=[],mietArr=[],kostenArr=[],cfArr=[],vermoegenArr=[];
  let rs=darlehen;
  for(let y=1;y<=haltedauer;y++){
    const z=rs*zinssatz/100;const ti=jahrestilgung;
    rs=Math.max(0,rs-ti);
    const m=jKaltmiete*Math.pow(1+mietsteigerung/100,y-1);
    const k=gesamtKosten;
    const cf=m*(1-mietausfallWagnis/100)-k-z-ti;
    const iv=kaufpreis*Math.pow(1+wertsteigerung/100,y);
    restschuldArr.push(rs);zinsenArr.push(z);tilgungArr.push(ti);
    mietArr.push(m);kostenArr.push(k+z+ti);cfArr.push(cf);vermoegenArr.push(iv-rs);
  }

  // Score
  let s=0;
  if(bruttoRendite>=5)s+=25;else if(bruttoRendite>=4)s+=15;else if(bruttoRendite>=3)s+=5;
  if(cfNachSteuer>0)s+=25;else if(cfNachSteuer>-2000)s+=10;
  if(ekRendite>=8)s+=25;else if(ekRendite>=5)s+=15;else if(ekRendite>=2)s+=5;
  if(kpFaktor<=20)s+=25;else if(kpFaktor<=25)s+=15;else if(kpFaktor<=30)s+=5;
  s=Math.min(100,s);

  return {nk_gew,nk_notar,nk_makler,gesamtNK,gesamtInv,nkPct,
    darlehen,jahreszins,jahrestilgung,jahresrate,monatsrate,
    jKaltmiete,mietausfall,effMiete,jVerwaltung,jInstand,jNichtUmlegbar,gesamtKosten,
    noi,cfVorSteuer,cfNachSteuer,
    bruttoRendite,nettoRendite,kpFaktor,
    gebWert,afaSatz,jAfA,steuerErspar,ekRendite,
    endwert,restschuld,ekEndwert,gesamtMiete,
    restschuldArr,zinsenArr,tilgungArr,mietArr,kostenArr,cfArr,vermoegenArr,
    years:Array.from({length:haltedauer},(_,i)=>i+1),score:s};
}

// ─── SLIDER FACTORY ───────────────────────────────────────────────────
function makeSlider(containerId,key,label,min,max,step,unit,hintFn){
  const container=document.getElementById(containerId);
  container.innerHTML=`
    <div class="slider-wrap">
      <div class="slider-top">
        <span class="slider-label">${label}</span>
        <span class="slider-val" id="${key}-display" title="Klicken zum Eingeben"></span>
      </div>
      <div class="slider-controls">
        <button class="step-btn" id="${key}-minus">−</button>
        <input type="range" id="${key}-range" min="${min}" max="${max}" step="${step}" value="${S[key]}"/>
        <button class="step-btn" id="${key}-plus">+</button>
      </div>
      ${hintFn?`<p class="hint" id="${key}-hint"></p>`:''}
    </div>`;

  let editing=false;
  const disp=document.getElementById(`${key}-display`);
  const range=document.getElementById(`${key}-range`);

  function formatVal(v){
    if(unit==='€')return fmtEur(v);
    if(unit==='%')return fmtPct(v);
    return `${fmtDE(v,step<1?2:0)} ${unit}`;
  }
  function update(v){
    S[key]=v;range.value=v;disp.textContent=formatVal(v);
    if(hintFn){const h=document.getElementById(`${key}-hint`);if(h)h.textContent=hintFn();}
    render();
  }
  function commitEdit(rawVal){
    const cleaned=rawVal.replace(/[^\d,.-]/g,'').replace(',','.');
    const parsed=parseFloat(cleaned);
    if(!isNaN(parsed)){
      const clamped=Math.min(max,Math.max(min,parsed));
      const rounded=Math.round(clamped/step)*step;
      update(parseFloat(rounded.toFixed(10)));
    }
    editing=false;
    disp.contentEditable='false';disp.style.outline='none';
  }
  disp.addEventListener('click',()=>{
    if(editing)return;editing=true;
    disp.contentEditable='true';disp.textContent=String(S[key]);
    disp.style.outline='1px solid #4fc3f7';disp.style.borderRadius='4px';
    disp.focus();
    const sel=window.getSelection();const r=document.createRange();r.selectNodeContents(disp);sel.removeAllRanges();sel.addRange(r);
  });
  disp.addEventListener('blur',()=>{if(editing)commitEdit(disp.textContent);});
  disp.addEventListener('keydown',e=>{
    if(e.key==='Enter'){e.preventDefault();commitEdit(disp.textContent);}
    if(e.key==='Escape'){editing=false;disp.contentEditable='false';disp.textContent=formatVal(S[key]);disp.style.outline='none';}
  });
  range.addEventListener('input',e=>update(parseFloat(e.target.value)));
  document.getElementById(`${key}-minus`).addEventListener('click',()=>{
    update(parseFloat(Math.max(min,Math.round((S[key]-step)/step)*step).toFixed(10)));
  });
  document.getElementById(`${key}-plus`).addEventListener('click',()=>{
    update(parseFloat(Math.min(max,Math.round((S[key]+step)/step)*step).toFixed(10)));
  });
  update(S[key]);
}

